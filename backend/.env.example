APP_ENV=local
PORT=4000

DATABASE_URL=postgresql://imgpull:imgpull@localhost:5432/imgpull
REDIS_URL=redis://localhost:6379

# P0 auth uses opaque session tokens and only stores token hashes.
# JWT_SECRET is reserved for future expansion and is not used by the P0 session flow.
JWT_SECRET=reserved_for_future_not_used_by_p0_session
SESSION_TTL_SECONDS=86400

PASSWORD_HASH_ALGO=pbkdf2_sha256
REGISTRY_SECRET_KEY=local_dev_placeholder_key_do_not_use_in_production
WORKER_TOKEN_SECRET=local_dev_worker_secret_placeholder

PAYMENT_ALIPAY_ENABLED=false
PAYMENT_WECHAT_ENABLED=false
WORKER_EXECUTION_ENABLED=false
